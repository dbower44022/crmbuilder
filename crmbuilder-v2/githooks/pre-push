#!/usr/bin/env bash
# Governance enforcement gate — pre-push backstop (REQ-320 / PI-287).
# Re-validates every code-touching, non-merge commit in the pushed range.
mode="${CRMBUILDER_GOVERNANCE_GATE:-warn}"
[ "$mode" = "off" ] && exit 0
root="$(git rev-parse --show-toplevel 2>/dev/null)" || exit 0
py="$root/.venv/bin/python3"
[ -x "$py" ] || py="$(command -v python3 || true)"
[ -x "$py" ] || exit 0
PYTHONPATH="$root/crmbuilder-v2/src${PYTHONPATH:+:$PYTHONPATH}" \
  "$py" -m crmbuilder_v2.governance_gate pre-push --mode "$mode"
