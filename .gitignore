# Python artifacts
__pycache__/
*.py[oc]
build/
dist/
wheels/
*.egg-info

# Virtual environments
.venv

# Testing
.pytest_cache/
.coverage
htmlcov/

# IDE
.vscode/
.idea/
*.swp
*.swo

# Instance profiles contain API keys
data/instances/*.json

# Recovery logs
data/recovery_logs/

# Reports are generated output
reports/*.log
reports/*.json

*.docx#

# Runtime databases (master.db, client databases)
automation/data/

# Client data — belongs in client repos, not here
data/programs/cbm_*.yaml
data/programs/*.yaml
data/instances/*.json
PRDs/Implementation Docs/
PRDs/generated/

*.db

# Pre-migration DB backups (recovery points; renamed past the .db suffix so
# the *.db rule above misses them) — e.g. engagements.db.pre-pi123-backup-*.
*.pre-*backup*

# v0.5 multi-engagement: per-engagement DBs and active-state files
# (`*.db` above already gitignores engagements.db and the dogfood backup
# and the per-engagement files; these lines document the v0.5 paths.)
crmbuilder-v2/data/engagements.db
crmbuilder-v2/data/engagements/
crmbuilder-v2/data/current_engagement.json
crmbuilder-v2/data/v2.db.pre-v0.5-backup

# Rotating API process logs (crmbuilder-v2-api). Runtime diagnostics,
# regenerated on every run — never committed.
crmbuilder-v2/data/logs/

# Client-supplied source store (WTK-111 §3.1/§3.5): held client record
# data — never under a git-tracked path.
crmbuilder-v2/data/sources/

# MCP OAuth authorization-server secrets (never commit)
crmbuilder-v2/data/oauth_jwt_secret
crmbuilder-v2/data/oauth_secrets.env

*.lock
crmbuilder-v2/data/mcp.env
