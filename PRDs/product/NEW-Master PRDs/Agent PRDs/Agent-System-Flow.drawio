<mxfile host="app.diagrams.net" type="device">
  <diagram id="agent-system-flow" name="Agent System Flow">
    <mxGraphModel dx="1000" dy="800" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="850" pageHeight="1700" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <!-- ===== group containers (declared first so they sit behind nodes) ===== -->
        <mxCell id="gHuman" value="HUMAN PLANNING (warm temperature)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#999999;dashed=1;verticalAlign=top;fontStyle=2;fontSize=12;align=left;spacingLeft=8;spacingTop=6;" vertex="1" parent="1">
          <mxGeometry x="150" y="40" width="300" height="290" as="geometry" />
        </mxCell>
        <mxCell id="gPipe" value="RELEASE PIPELINE — conductor (release_runtime.py)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#999999;dashed=1;verticalAlign=top;fontStyle=2;fontSize=12;align=left;spacingLeft=8;spacingTop=6;" vertex="1" parent="1">
          <mxGeometry x="150" y="430" width="300" height="270" as="geometry" />
        </mxCell>
        <mxCell id="gAdo" value="ADO DEV-ORG — runs each Planning Item (ado_runtime.py)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#999999;dashed=1;verticalAlign=top;fontStyle=2;fontSize=12;align=left;spacingLeft=8;spacingTop=6;" vertex="1" parent="1">
          <mxGeometry x="150" y="720" width="300" height="620" as="geometry" />
        </mxCell>

        <!-- ===== human planning ===== -->
        <mxCell id="REQ" value="&lt;b&gt;Requirement&lt;/b&gt;&lt;br&gt;(human-approved)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1">
          <mxGeometry x="180" y="75" width="240" height="50" as="geometry" />
        </mxCell>
        <mxCell id="PRJ" value="&lt;b&gt;Project (PRJ)&lt;/b&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1">
          <mxGeometry x="180" y="140" width="240" height="35" as="geometry" />
        </mxCell>
        <mxCell id="PI" value="&lt;b&gt;Planning Items (PI)&lt;/b&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1">
          <mxGeometry x="180" y="190" width="240" height="35" as="geometry" />
        </mxCell>
        <mxCell id="RELplan" value="&lt;b&gt;Release (REL)&lt;/b&gt;&lt;br&gt;batch whole projects (+ their PIs)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1">
          <mxGeometry x="180" y="240" width="240" height="55" as="geometry" />
        </mxCell>

        <!-- ===== freeze ===== -->
        <mxCell id="FREEZE" value="&lt;b&gt;Plan Freeze&lt;/b&gt;&lt;br&gt;a transition, not a switch" style="shape=hexagon;perimeter=hexagonPerimeter2;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;" vertex="1" parent="1">
          <mxGeometry x="210" y="350" width="180" height="65" as="geometry" />
        </mxCell>

        <!-- ===== release pipeline ===== -->
        <mxCell id="RECON" value="&lt;b&gt;Reconciliation&lt;/b&gt;&lt;br&gt;merge all demands → find conflicts&lt;br&gt;(reconciliation engine)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1">
          <mxGeometry x="180" y="460" width="240" height="60" as="geometry" />
        </mxCell>
        <mxCell id="ARCH" value="&lt;b&gt;Architecture Planning&lt;/b&gt;&lt;br&gt;author designs (versioning spine)&lt;br&gt;+ decompose into Work Tasks" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1">
          <mxGeometry x="180" y="535" width="240" height="70" as="geometry" />
        </mxCell>
        <mxCell id="READY" value="&lt;b&gt;Release: ready&lt;/b&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1">
          <mxGeometry x="210" y="620" width="180" height="40" as="geometry" />
        </mxCell>

        <!-- ===== ADO dev-org ===== -->
        <mxCell id="DEV" value="&lt;b&gt;Development lane&lt;/b&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1">
          <mxGeometry x="210" y="745" width="180" height="35" as="geometry" />
        </mxCell>
        <mxCell id="PM" value="&lt;b&gt;Project Manager Agent&lt;/b&gt;&lt;br&gt;dispatch next eligible PI" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;" vertex="1" parent="1">
          <mxGeometry x="180" y="795" width="240" height="50" as="geometry" />
        </mxCell>
        <mxCell id="LEAD" value="&lt;b&gt;PI Lead Agent&lt;/b&gt;&lt;br&gt;open each phase in order" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;" vertex="1" parent="1">
          <mxGeometry x="180" y="860" width="240" height="45" as="geometry" />
        </mxCell>
        <mxCell id="DECOMP" value="&lt;b&gt;Decompose&lt;/b&gt;&lt;br&gt;Plan: Design → Develop → Test&lt;br&gt;chained by blocked_by" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;" vertex="1" parent="1">
          <mxGeometry x="180" y="920" width="240" height="55" as="geometry" />
        </mxCell>
        <mxCell id="SCOPE" value="&lt;b&gt;Phase Specialist Agent&lt;/b&gt;&lt;br&gt;scope phase → Work Tasks" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;" vertex="1" parent="1">
          <mxGeometry x="180" y="990" width="240" height="50" as="geometry" />
        </mxCell>
        <mxCell id="POOL" value="&lt;b&gt;Area Specialist Agents&lt;/b&gt; (workers)&lt;br&gt;parallel pool, own git worktrees&lt;br&gt;(parallel_runtime.py)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;" vertex="1" parent="1">
          <mxGeometry x="180" y="1055" width="240" height="65" as="geometry" />
        </mxCell>
        <mxCell id="GATE" value="&lt;b&gt;Reconciliation gate&lt;/b&gt;&lt;br&gt;Design settled + no blocking findings (FND)?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;" vertex="1" parent="1">
          <mxGeometry x="185" y="1140" width="230" height="75" as="geometry" />
        </mxCell>
        <mxCell id="MERGE" value="verify by result →&lt;br&gt;merge each branch" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;" vertex="1" parent="1">
          <mxGeometry x="180" y="1230" width="240" height="45" as="geometry" />
        </mxCell>
        <mxCell id="COMPLETE" value="complete phase →&lt;br&gt;PI: In Review" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;" vertex="1" parent="1">
          <mxGeometry x="180" y="1290" width="240" height="45" as="geometry" />
        </mxCell>

        <!-- ===== release gates + ship ===== -->
        <mxCell id="QA" value="&lt;b&gt;Release QA gate&lt;/b&gt;&lt;br&gt;design covers every requirement?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;" vertex="1" parent="1">
          <mxGeometry x="185" y="1370" width="230" height="65" as="geometry" />
        </mxCell>
        <mxCell id="TEST" value="&lt;b&gt;Release Test gate&lt;/b&gt;&lt;br&gt;processes hold end-to-end?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;" vertex="1" parent="1">
          <mxGeometry x="185" y="1455" width="230" height="65" as="geometry" />
        </mxCell>
        <mxCell id="DEPLOY" value="&lt;b&gt;deployment&lt;/b&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1">
          <mxGeometry x="210" y="1540" width="180" height="40" as="geometry" />
        </mxCell>
        <mxCell id="SHIP" value="&lt;b&gt;shipped&lt;/b&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;" vertex="1" parent="1">
          <mxGeometry x="210" y="1600" width="180" height="45" as="geometry" />
        </mxCell>

        <!-- ===== side: registry + locks ===== -->
        <mxCell id="REG" value="&lt;b&gt;Agent Profile Registry&lt;/b&gt;&lt;br&gt;profile + skills + rules + learnings → contract" style="shape=note;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;" vertex="1" parent="1">
          <mxGeometry x="520" y="1005" width="210" height="75" as="geometry" />
        </mxCell>
        <mxCell id="LOCKS" value="&lt;b&gt;Locks&lt;/b&gt;&lt;br&gt;file/resource + migration lock&lt;br&gt;keep workers apart" style="shape=note;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="1">
          <mxGeometry x="520" y="1100" width="210" height="75" as="geometry" />
        </mxCell>

        <!-- ===== edges ===== -->
        <mxCell id="e1" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;" edge="1" parent="1" source="REQ" target="PRJ"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e2" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;" edge="1" parent="1" source="PRJ" target="PI"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e3" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;" edge="1" parent="1" source="PI" target="RELplan"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e4" value="human freezes the plan" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;" edge="1" parent="1" source="RELplan" target="FREEZE"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e5" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;" edge="1" parent="1" source="FREEZE" target="RECON"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e6" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;" edge="1" parent="1" source="RECON" target="ARCH"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e7" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;" edge="1" parent="1" source="ARCH" target="READY"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e8" value="single-occupancy: one release in the lane" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;" edge="1" parent="1" source="READY" target="DEV"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e9" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;" edge="1" parent="1" source="DEV" target="PM"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e10" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;" edge="1" parent="1" source="PM" target="LEAD"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e11" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;" edge="1" parent="1" source="LEAD" target="DECOMP"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e12" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;" edge="1" parent="1" source="DECOMP" target="SCOPE"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e13" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;" edge="1" parent="1" source="SCOPE" target="POOL"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e14" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;" edge="1" parent="1" source="POOL" target="GATE"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e15" value="yes" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;" edge="1" parent="1" source="GATE" target="MERGE"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e16" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;" edge="1" parent="1" source="MERGE" target="COMPLETE"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e17" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;" edge="1" parent="1" source="COMPLETE" target="QA"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e18" value="pass" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;" edge="1" parent="1" source="QA" target="TEST"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e19" value="pass" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;" edge="1" parent="1" source="TEST" target="DEPLOY"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e20" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;" edge="1" parent="1" source="DEPLOY" target="SHIP"><mxGeometry relative="1" as="geometry" /></mxCell>

        <!-- fail back-edges to development lane -->
        <mxCell id="e21" value="fail" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;dashed=1;strokeColor=#b85450;exitX=0;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" edge="1" parent="1" source="QA" target="DEV"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e22" value="fail" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;dashed=1;strokeColor=#b85450;exitX=0;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" edge="1" parent="1" source="TEST" target="DEV"><mxGeometry relative="1" as="geometry" /></mxCell>

        <!-- support edges (dashed) -->
        <mxCell id="e23" value="supplies contract" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=open;dashed=1;strokeColor=#666666;" edge="1" parent="1" source="REG" target="POOL"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e24" value="guards" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=open;dashed=1;strokeColor=#666666;" edge="1" parent="1" source="LOCKS" target="POOL"><mxGeometry relative="1" as="geometry" /></mxCell>

        <!-- note: two decompose paths -->
        <mxCell id="NOTE" value="Note: in a release-driven run, Decompose/Scope happen in Architecture Planning and the ADO only EXECUTES the pre-scoped Work Tasks. In a standalone ADO run, the ADO does Decompose/Scope itself (as drawn)." style="text;html=1;align=left;verticalAlign=top;whiteSpace=wrap;fontSize=11;fontColor=#666666;" vertex="1" parent="1">
          <mxGeometry x="480" y="780" width="320" height="120" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
