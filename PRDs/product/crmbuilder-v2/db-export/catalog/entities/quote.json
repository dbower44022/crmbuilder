      "is_standard": "true",
      "mechanism": null,
      "name": "Quote",
      "notes": "Standard CRM object. HubSpot Quotes auto-generate from Deals with associated line items. Includes quote-template selection, e-signature integration (DocuSign / native HubSpot Sign), and customer-facing web preview links. Quote pricing flows back into the Deal amount when the Quote is accepted.",
      "system": "hubspot"
