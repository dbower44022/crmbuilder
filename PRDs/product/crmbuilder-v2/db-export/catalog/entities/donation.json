  "systems": [
    {
      "api_name": "not_applicable",
      "docs_url": "https://attio.com/help/reference/managing-your-data/objects/create-and-manage-custom-objects",
      "is_standard": "false",
      "mechanism": null,
      "name": "(custom object required)",
      "notes": "Attio has no native Donation entity. Nonprofits would build a custom object linked to People and Companies.",
      "system": "attio"
    },
    {
      "api_name": "Transaction",
      "docs_url": "https://bloomerang.com/api/rest-api-v1/",
      "is_standard": "true",
      "mechanism": null,
      "name": "Transaction (received) / Pledge (committed)",
      "notes": "Bloomerang uses Transaction for received donations and Pledge for committed-but-unpaid. Transaction records include amount, date, method (Cash, Check, Credit Card, etc.), fund (allocation), campaign, appeal, acknowledgment status. Receipt PDF generation is a built-in feature.",
      "system": "bloomerang"
    },
    {
      "api_name": "Contribution",
      "docs_url": "https://docs.civicrm.org/user/en/latest/contributions/",
      "is_standard": "true",
      "mechanism": null,
      "name": "Contribution",
      "notes": "CiviCRM's first-class Contribution entity. Includes total_amount, receive_date, financial_type_id (Donation, Member Dues, Campaign Contribution, Event Fee), payment_instrument_id, contribution_status_id (Completed, Pending, Cancelled, Failed, Refunded, In Progress), source, contribution_recur_id (links to ContributionRecur), campaign_id. Tax-receipt PDF generation is built-in.",
      "system": "civicrm"
    },
    {
      "api_name": "Opportunity",
      "docs_url": "https://github.com/espocrm/espocrm/blob/master/application/Espo/Modules/Crm/Resources/metadata/entityDefs/Opportunity.json",
      "is_standard": "false",
      "mechanism": null,
      "name": "Opportunity (no Donation entity)",
      "notes": "EspoCRM has no Donation entity. Nonprofit deployments use Opportunity with custom stages and fields, similar to vanilla Salesforce pattern.",
      "system": "espocrm"
    },
    {
      "api_name": "deals",
      "docs_url": "https://developers.hubspot.com/docs/api-reference/crm-deals-v3/guide",
      "is_standard": "false",
      "mechanism": null,
      "name": "Deal (with custom Type)",
      "notes": "HubSpot has no Donation entity. Nonprofits using HubSpot configure Deals with a Donation pipeline, custom Deal Type values, and custom properties for tax-receipt fields.",
      "system": "hubspot"
    },
    {
      "api_name": "Opportunity",
      "docs_url": "https://developer.salesforce.com/docs/atlas.en-us.object_reference.meta/object_reference/sforce_api_objects_opportunity.htm",
      "is_standard": "false",
      "mechanism": null,
      "name": "Opportunity (no Donation entity in vanilla Salesforce)",
      "notes": "Vanilla Salesforce has no Donation entity. Customers without NPSP typically build donation tracking via custom Opportunity Record Types and a flock of custom fields. Not turnkey.",
      "system": "salesforce"
    },
    {
      "api_name": "Opportunity",
      "docs_url": "https://developer.salesforce.com/docs/platform/data-models/guide/nonprofit-success-pack.html",
      "is_standard": "true",
      "mechanism": null,
      "name": "Opportunity (Donation Record Type)",
      "notes": "NPSP repurposes Opportunity for donations via a Donation Record Type (also Major Gift, Grant, In-Kind Gift, Matching Gift, Membership record types). Pledged stage = committed; Closed Won (or Posted) = received. NPSP custom fields add donor-acknowledgment tracking, tax receipt fields, and rollup fields (Total Gifts, Last Gift Amount, Largest Gift Amount on the related Contact and Household Account). Payment is a separate child object (npe01__OppPayment__c).",
      "system": "salesforce_npsp"
    }
  ],
