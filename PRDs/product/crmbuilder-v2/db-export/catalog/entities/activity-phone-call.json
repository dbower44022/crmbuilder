  "is_deleted": false,
  "name": "Phone Call (Activity subclass)",
  "parent_catalog_id": "activity",
  "purpose": "A voice call placed or received as part of a relationship. A subclass of Activity that adds phone-specific delta attributes: phone number dialed, direction (outbound / inbound), call duration, optional recording URL.",
